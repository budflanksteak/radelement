{
  "rewrites": [
    { "source": "/api/radelement/:path*", "destination": "/api/radelement/:path*" },
    { "source": "/api/snomed/:path*",     "destination": "/api/snomed/:path*" },
    { "source": "/api/bioportal/:path*",  "destination": "/api/bioportal/:path*" },
    { "source": "/(.*)",                  "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
