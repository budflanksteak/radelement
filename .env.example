# ── Local development (Vite dev server) ──────────────────────────────────────
# BioPortal API key injected into the browser bundle by Vite.
# Get a free key at https://bioportal.bioontology.org/account
VITE_BIOPORTAL_KEY=your_key_here

# ── Production (Vercel) ───────────────────────────────────────────────────────
# Same key, but set as a plain server-side env var in the Vercel dashboard.
# The Vercel Edge Function reads process.env.BIOPORTAL_KEY — NOT the VITE_ version.
# Set this in: Vercel dashboard → Project → Settings → Environment Variables
#   Key:   BIOPORTAL_KEY
#   Value: your_key_here
